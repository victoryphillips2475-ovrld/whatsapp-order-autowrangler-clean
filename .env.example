# .env.example – required variables for the WhatsApp Order Auto‑Wrangler backend
# Copy this file to .env and fill in real values. Do NOT commit secrets.

# ---------------------------------------------------------------------------
# Core environment
# ---------------------------------------------------------------------------
APP_ENV=development   # one of: development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000

# Coolify integration
COOLIFY_BASE_URL=https://coolify-nexus-forge.freeddns.org
COOLIFY_API_KEY=YOUR_COOLIFY_API_KEY

# ---------------------------------------------------------------------------
# CORS – comma‑separated list of allowed origins (e.g. https://example.com)
# ---------------------------------------------------------------------------
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# JWT – generate a 256‑bit secret and base64‑encode it.
# ---------------------------------------------------------------------------
JWT_SECRET=YOUR_BASE64_256_BIT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Appwrite – create a server SDK key with appropriate permissions.
# ---------------------------------------------------------------------------
APPWRITE_ENDPOINT=https://appwrite.example.com/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_DATABASE_ID=your-database-id

# ---------------------------------------------------------------------------
# WhatsApp – Baileys placeholder values (replace with real numbers when
# the integration is built).
# ---------------------------------------------------------------------------
WHATSAPP_PHONE=+15551234567
WHATSAPP_SESSION_ID=default_session

# ---------------------------------------------------------------------------
# Webhook (Baileys Node → FastAPI)
# In production: set WEBHOOK_SECRET to a random string and share it with
# the WhatsApp Node service so it can authenticate incoming calls.
# WEBHOOK_DEFAULT_USER_ID is the Appwrite user_id used for orders created
# from WhatsApp messages (set to the merchant's user ID in production).
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=your_random_webhook_secret
WEBHOOK_DEFAULT_USER_ID=

# ---------------------------------------------------------------------------
# Optional payment provider credentials (populate if you enable the feature)
# ---------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=