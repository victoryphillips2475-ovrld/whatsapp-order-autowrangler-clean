# .env.example – WhatsApp Baileys Node service
# Copy this file to .env and fill in real values. Do NOT commit secrets.

# ---------------------------------------------------------------------------
# FastAPI backend URL (must match the server running the FastAPI backend)
# In Docker: use the service name, e.g. http://orderstream-backend:8000
# ---------------------------------------------------------------------------
FASTAPI_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Webhook secret – must match WEBHOOK_SECRET in the FastAPI .env
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=your_random_webhook_secret