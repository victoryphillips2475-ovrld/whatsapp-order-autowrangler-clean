# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT
JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Appwrite
APPWRITE_ENDPOINT=http://100.87.228.1/v1
APPWRITE_PROJECT_ID=YOUR_PROJECT_ID
APPWRITE_API_KEY=YOUR_API_KEY
APPWRITE_DATABASE_ID=YOUR_DATABASE_ID

# WhatsApp Baileys (placeholder)
WHATSAPP_PHONE=+1234567890
WHATSAPP_SESSION_ID=default_session

# Webhook — user ID for orders created via WhatsApp (no JWT context)
WEBHOOK_DEFAULT_USER_ID=your_appwrite_user_id

# Payments (optional)
PAYSTACK_SECRET_KEY=your_paystack_key
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
